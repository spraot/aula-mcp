{
  "name": "@aula-mcp/mcp-server",
  "version": "1.1.0",
  "private": true,
  "description": "Hono-based MCP server exposing Aula data to AI agents. Runs on Bun.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
