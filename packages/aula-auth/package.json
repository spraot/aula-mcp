{
  "name": "@aula-mcp/aula-auth",
  "version": "0.0.0",
  "private": true,
  "description": "MitID + SRP + OAuth/SAML auth flow for Aula. Pure HTTP, no headless browser.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
