{
  "name": "aula-mcp",
  "version": "0.0.0",
  "private": true,
  "description": "MCP server for the Danish Aula school platform — TypeScript port of scaarup/aula.",
  "license": "MIT",
  "author": "Casper Juel <cj@signifly.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Casperjuel/aula-mcp.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20.10"
  },
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^7.1.13",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild"
    ]
  }
}
