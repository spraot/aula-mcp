{
  "name": "aula-mcp",
  "version": "0.0.0",
  "private": true,
  "description": "MCP server for the Danish Aula school platform — TypeScript port of scaarup/aula.",
  "license": "MIT",
  "author": "Casper Juel <info@casperjuel.dk>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Casperjuel/aula-mcp.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20.10"
  },
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "aula": "bun apps/cli/src/index.ts",
    "mcp": "bun packages/mcp-server/src/server.ts",
    "login": "bun apps/cli/src/index.ts login",
    "doctor": "bun apps/cli/src/index.ts doctor",
    "whoami": "bun apps/cli/src/index.ts whoami",
    "status": "bun apps/cli/src/index.ts status",
    "logout": "bun apps/cli/src/index.ts logout",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild"
    ]
  }
}
