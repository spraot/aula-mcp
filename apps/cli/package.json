{
  "name": "@aula-mcp/cli",
  "version": "1.0.0",
  "private": true,
  "description": "Command-line entry point for aula-mcp: login, status, logout.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "aula": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "build:bin": "bun build --compile --outfile bin/aula src/index.ts"
  },
  "dependencies": {
    "@aula-mcp/aula-auth": "workspace:*",
    "@aula-mcp/aula-client": "workspace:*",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/qrcode-terminal": "^0.12.2"
  }
}
